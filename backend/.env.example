# FastAPI Configuration
APP_NAME=AI-PECO
APP_VERSION=1.0.0
DEBUG=False

# MongoDB
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net
DATABASE_NAME=aipeco_db
SECRET_KEY=your-secret-key-min-32-characters-long
CORS_ORIGINS=http://localhost:3000,https://ai-peco.vercel.app

# ESP32 Configuration
ESP32_POLLING_INTERVAL=5
DATA_RETENTION_DAYS=30
DEVICE_API_KEY=change-me-for-production

# Energy Settings
ENERGY_PRICE_PER_UNIT=50
ANOMALY_THRESHOLD_SIGMA=2.0

# Features
ENABLE_AI_PREDICTIONS=True
ENABLE_AUTO_ALERTS=True
