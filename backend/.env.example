APP_NAME=AI-PECO
APP_VERSION=1.0.0
DEBUG=False

# MongoDB Atlas (get free cluster at mongodb.com/atlas)
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/aipeco_db
DATABASE_NAME=aipeco_db

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-minimum-32-characters-long-change-this

# CORS — add your Vercel frontend URL here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# Demo mode — set false when ESP32 hardware is connected
DEMO_MODE=true

# ESP32 Configuration
ESP32_POLLING_INTERVAL=5
DATA_RETENTION_DAYS=30
DEVICE_API_KEY=change-me-for-production

# Energy Settings (PKR per kWh)
ENERGY_PRICE_PER_UNIT=50
ANOMALY_THRESHOLD_SIGMA=2.0

# Features
ENABLE_AI_PREDICTIONS=True
ENABLE_AUTO_ALERTS=True
