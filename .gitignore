# ============================
# AI-PECO .gitignore
# ============================

# ----- Node / Frontend -----
node_modules/
frontend/node_modules/
dist/
dist-ssr/
build/
*.local
frontend/dist/

# ----- Frontend lock files (Vercel installs fresh) -----
# Keep frontend/package-lock.json — needed for reproducible builds
# package-lock.json at root is not needed

# ----- Environment files -----
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local
# Keep .env.example and .env.production (they have no secrets)

# ----- Python virtual environments -----
venv/
.venv/
env/
backend/venv/
backend/venv_new/
backend/ml_venv/

# ----- Python cache -----
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyd

# ----- AI / ML large binary files -----
# Dataset (124MB — way too large for GitHub)
backend/ai/data/household_power_consumption.txt
backend/ai/data/*.txt
backend/ai/data/*.csv

# Trained model binaries (generated by train.py — not needed in repo)
backend/ai/saved_models/*.keras
backend/ai/saved_models/*.pkl
backend/ai/saved_models/*.json
backend/ai/saved_models/training_plots/

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend/error.txt
backend/startup_log.txt

# ----- Editor / IDE -----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- OS files -----
.DS_Store
Thumbs.db
desktop.ini