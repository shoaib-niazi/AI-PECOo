# ============================
# AI-PECO .gitignore
# ============================

# ----- Dependencies -----
node_modules/
package-lock.json

# ----- Build output -----
dist/
dist-ssr/
build/
*.local

# ----- Environment files -----
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

# ----- Python -----
backend/venv/
backend/venv_new/
backend/ml_venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# ----- AI / ML artifacts (large binary files) -----
backend/ai/data/household_power_consumption.txt
backend/ai/saved_models/*.keras
backend/ai/saved_models/*.pkl
backend/ai/saved_models/*.json
backend/ai/saved_models/training_plots/

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend/error.txt
backend/startup_log.txt

# ----- Editor / IDE -----
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# ----- OS files -----
.DS_Store
desktop.ini
# Ignore Python virtual environments
backend/ml_venv/
venv/
.venv/
env/

# Ignore large datasets
backend/ai/data/household_power_consumption.txt
*.txt
*.csv